# Virtual environment
.venv/

# Python
__pycache__/
*.pyc

# Editor / OS
.DS_Store
.ipynb_checkpoints/

# Raw FAERS / OpenVigil pulls: large, never commit.
# Ignore everything under data/raw/ except its own README (which documents
# source/date/counts and is meant to be committed).
data/raw/*
!data/raw/README.md
data/**/*.zip
data/**/*.txt

# data/processed/ is tracked by default (small derived CSVs only).
# .gitignore cannot filter by file size -- before committing anything
# under data/processed/, manually confirm it is <5 MB. If a derived
# file grows past that, move it to data/raw/ (git-ignored) or add an
# explicit path exclusion below instead of committing it.

# Local case-level extracts derived from PMDA JADER. PMDA's terms generally
# prohibit redistribution of the database; publish aggregate results and code,
# not these rows. Users regenerate them from a release obtained from PMDA.
data/processed/jader_dato_cases.csv
data/processed/jader_dato_case_pt.csv
